{
  "description": "HekateSSH PreToolUse hook: delegate host-affecting ssh MCP tool calls to the resident HekateSSH daemon policy gate.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__ssh__(exec|get|put|sync_get|sync_put)",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/tools/hekatessh-hook.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
